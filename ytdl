#!/usr/bin/env bash
set -euo pipefail

VERSION="1.0.0"

usage() {
  cat <<EOF
ytdl v${VERSION} — Download YouTube audio as production-ready WAV

Usage:
  ytdl <url> [start] [end] [-o dir]

Arguments:
  url        YouTube URL (required)
  start      Start timestamp as MM:SS or HH:MM:SS (optional)
  end        End timestamp as MM:SS or HH:MM:SS (required if start is set)

Options:
  -o DIR     Output directory (default: ~/Downloads)
  --verbose  Show full yt-dlp and ffmpeg output
  -h         Show this help
  -v         Show version

Output:
  44.1kHz / 24-bit WAV, filename sanitized and truncated to ${MAX_TITLE} chars.

Examples:
  ytdl "https://youtube.com/watch?v=abc123"
  ytdl "https://youtube.com/watch?v=abc123" 1:30 3:45
  ytdl "https://youtube.com/watch?v=abc123" 1:30 3:45 -o ~/Music/Samples
EOF
}

die() { echo "error: $1" >&2; exit 1; }

MAX_TITLE=50
VERBOSE=false
URL=""
START=""
END=""
OUTDIR="$HOME/Downloads"

[[ $# -eq 0 ]] && { usage; exit 0; }

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help|help)  usage; exit 0 ;;
    -v|--version|version) echo "ytdl v${VERSION}"; exit 0 ;;
    -o|--outdir)
      [[ -z "${2:-}" ]] && die "-o requires a directory argument"
      OUTDIR="$2"; shift 2 ;;
    --verbose)    VERBOSE=true; shift ;;
    -*)           die "unknown option: $1" ;;
    *)
      if [[ -z "$URL" ]]; then
        URL="$1"
      elif [[ -z "$START" ]]; then
        START="$1"
      elif [[ -z "$END" ]]; then
        END="$1"
      else
        die "unexpected argument: $1"
      fi
      shift
      ;;
  esac
done

[[ -z "$URL" ]] && { usage; die "url is required"; }

if [[ ! "$URL" =~ ^https?://(www\.)?(youtube\.com|youtu\.be|music\.youtube\.com)/ ]]; then
  die "not a valid YouTube URL: $URL"
fi

[[ -n "$START" && -z "$END" ]] && die "start timestamp requires an end timestamp"
[[ -n "$END" && -z "$START" ]] && die "end timestamp requires a start timestamp"

ts_pattern='^([0-9]{1,2}:)?[0-9]{1,2}:[0-9]{2}$'
if [[ -n "$START" ]]; then
  [[ "$START" =~ $ts_pattern ]] || die "invalid start timestamp: $START (expected MM:SS or HH:MM:SS)"
  [[ "$END" =~ $ts_pattern ]] || die "invalid end timestamp: $END (expected MM:SS or HH:MM:SS)"
fi

mkdir -p "$OUTDIR" || die "cannot create output directory: $OUTDIR"

command -v yt-dlp >/dev/null 2>&1 || die "yt-dlp not found. Install with: brew install yt-dlp"
command -v ffmpeg >/dev/null 2>&1 || die "ffmpeg not found. Install with: brew install ffmpeg"

BAR_WIDTH=40

progress_bar() {
  local pct=$1 label=$2
  local filled=$((pct * BAR_WIDTH / 100))
  local empty=$((BAR_WIDTH - filled))
  printf "\r  [%-${BAR_WIDTH}s] %3d%%  %s" "$(printf '#%.0s' $(seq 1 $filled 2>/dev/null))" "$pct" "$label"
}

TMPDIR=$(mktemp -d)
trap 'printf "\n"; rm -rf "$TMPDIR"; kill 0 2>/dev/null; exit 130' INT
trap 'rm -rf "$TMPDIR"' EXIT

if [[ "$VERBOSE" == false ]]; then
  progress_bar 0 "fetching info..."
fi
TITLE=$(yt-dlp --print "%(title).${MAX_TITLE}s" "$URL" 2>/dev/null) || die "failed to fetch video title"
TITLE="${TITLE//[^a-zA-Z0-9._-]/_}"
OUTFILE="$OUTDIR/${TITLE}.wav"
if [[ -f "$OUTFILE" ]]; then
  n=2
  while [[ -f "$OUTDIR/${TITLE}_${n}.wav" ]]; do
    n=$((n + 1))
  done
  OUTFILE="$OUTDIR/${TITLE}_${n}.wav"
fi

dl_args=(
  -x
  --restrict-filenames
  --no-warnings
  -o "$TMPDIR/audio.%(ext)s"
)

if [[ "$VERBOSE" == false ]]; then
  dl_args+=(--newline --progress-template "%(progress._percent_str)s")
fi

dl_args+=("$URL")

if [[ "$VERBOSE" == true ]]; then
  yt-dlp "${dl_args[@]}" || die "yt-dlp download failed"
else
  PYTHONUNBUFFERED=1 yt-dlp "${dl_args[@]}" 2>/dev/null | while IFS= read -r line; do
    if [[ "$line" =~ ([0-9]+(\.[0-9]+)?)% ]]; then
      dl_pct=${BASH_REMATCH[1]%%.*}
      pct=$((dl_pct * 90 / 100))
      progress_bar "$pct" "downloading..."
    fi
  done
  [[ ${PIPESTATUS[0]} -eq 0 ]] || die "yt-dlp download failed"
fi

SRC=$(find "$TMPDIR" -type f | head -1)
[[ -z "$SRC" ]] && die "no file downloaded"

ff_args=(-y)
[[ "$VERBOSE" == false ]] && ff_args+=(-loglevel error)
ff_args+=(-i "$SRC")
[[ -n "$START" && -n "$END" ]] && ff_args+=(-ss "$START" -to "$END")
ff_args+=(-ar 44100 -c:a pcm_s24le "$OUTFILE")

if [[ "$VERBOSE" == true ]]; then
  ffmpeg "${ff_args[@]}" || die "ffmpeg conversion failed"
else
  progress_bar 90 "converting..."
  ffmpeg "${ff_args[@]}" || die "ffmpeg conversion failed"
  progress_bar 100 "done"
  printf "\n"
fi

echo "saved: $OUTFILE"
